# 複製成 .env.local（已被 .gitignore 封鎖，不會進 git）
# 設定教學：scripts/README_social.md

# 德國知識小種子 FB 粉專的數字 ID
FB_PAGE_ID=

# Meta System User Token（永不過期；權限：pages_show_list, pages_manage_posts,
# pages_read_engagement, instagram_basic, instagram_content_publish, business_management）
FB_PAGE_TOKEN=

# IG 商業帳號 ID（選填——不填會自動從粉專解析）
IG_USER_ID=

# 選填
# FB_API_VERSION=v21.0
# SITE_BASE=https://taiwanese-in-germany.com
